# Copy this file to .env and fill in real values

FLASK_ENV=development
SECRET_KEY=please-change-me-in-production

# MySQL connection (PyMySQL driver)
DATABASE_URL=mysql+pymysql://root:rootpass@127.0.0.1:3306/gongfeng?charset=utf8mb4

# JWT
JWT_SECRET=please-change-me-jwt-secret-32+chars
JWT_EXPIRES_HOURS=2

# CORS allowed origins (comma separated; * for any)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
